# ============================================================
# Project Atlas — environment variable reference
# Copy this file to .env and fill in real values.
# Never commit .env to version control.
#
# Edge (offline) setup: run scripts/setup.sh to download all
# models and dependencies into .local/ before starting.
# ============================================================

# ------------------------------------------------------------
# Local storage paths (edge / offline mode)
# All paths must stay inside the project directory (.local/).
# scripts/setup.sh creates these directories automatically.
# ------------------------------------------------------------

# Ollama model storage — overrides default ~/.ollama location
OLLAMA_MODELS=./.local/ollama

# HuggingFace / MLX model cache — overrides ~/.cache/huggingface
HF_HOME=./.local/mlx

# Atlas runtime directories (used by worker and API services)
ATLAS_MLX_DIR=./.local/mlx
ATLAS_UPLOAD_DIR=./.local/uploads
ATLAS_EMBEDDINGS_DIR=./.local/embeddings
ATLAS_TMP_DIR=./.local/tmp

# ------------------------------------------------------------
# Inference — Ollama (LLMs + embeddings, runs locally)
# ------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434

# Primary LLM for compilation, answers, and synthesis
OLLAMA_DEFAULT_MODEL=gemma4:26b

# Embedding model for search indexing
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ------------------------------------------------------------
# Inference — MLX (speech-to-text + vision on Apple Silicon)
# Models download into .local/mlx/ on first inference call.
# ------------------------------------------------------------

# Whisper model size: tiny | base | small | medium | large-v3
# large-v3 is recommended for production (~3 GB, highest accuracy)
WHISPER_MODEL_SIZE=large-v3

# Vision/OCR model for PDF image extraction and screenshots
VLM_MODEL=gemma-4-12b-vision

# Text-to-speech (Phase 6+, disabled by default)
ENABLE_TTS=false

# ------------------------------------------------------------
# Model profile
# Overrides individual model settings with a named preset.
# Options: light | standard | reasoning | polyglot | maximum
#
#   light     — gemma4 + whisper/small     fast, ~8 GB RAM
#   standard  — gemma4:26b + whisper/large-v3  balanced (default)
#   reasoning — qwen3.5-27b + large-v3         deeper synthesis
#   polyglot  — gemma4:26b + large-v3          multilingual focus
#   maximum   — gemma4:26b + qwen3.5-27b       highest quality
# ------------------------------------------------------------
MODEL_PROFILE=standard

# ------------------------------------------------------------
# Feature flags
# ------------------------------------------------------------

# LLM-assisted synthesis in the compiler (summaries, entities, concepts)
ENABLE_LLM_SYNTHESIS=true

# Audio file ingestion via lightning-whisper-mlx
ENABLE_AUDIO_INGEST=true

# Vision/OCR extraction via mlx-vlm
ENABLE_VISION_EXTRACTION=true

# ------------------------------------------------------------
# Adapter feature flags
# All adapters use local Ollama models — no cloud API keys needed.
# ------------------------------------------------------------

# DeerFlow: multi-step research orchestration
ENABLE_DEERFLOW=true
DEERFLOW_MODEL=gemma4:26b

# Hermes: memory bridge / context retrieval
ENABLE_HERMES=true
HERMES_MODEL=gemma4

# MiroFish: scenario simulation (premium — requires separate license)
ENABLE_MIROFISH=false
MIROFISH_MODEL=qwen3.5-27b-claude-distilled

# ------------------------------------------------------------
# PostgreSQL
# ------------------------------------------------------------
POSTGRES_DB=atlas_dev
POSTGRES_USER=atlas
POSTGRES_PASSWORD=atlas_dev_password
POSTGRES_PORT=5432

# Full DSN used by services/api and services/worker (SQLAlchemy / asyncpg)
DATABASE_URL=postgresql+asyncpg://atlas:atlas_dev_password@localhost:5432/atlas_dev

# Sync DSN used by Alembic migrations
DATABASE_SYNC_URL=postgresql://atlas:atlas_dev_password@localhost:5432/atlas_dev

# ------------------------------------------------------------
# Redis
# ------------------------------------------------------------
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# Separate DB index for job queues (ARQ / Celery)
REDIS_QUEUE_URL=redis://localhost:6379/1

# ------------------------------------------------------------
# API service (services/api)
# ------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true

# Secret used to sign JWT tokens — must be a long random string in production
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ------------------------------------------------------------
# Worker service (services/worker)
# ------------------------------------------------------------
WORKER_CONCURRENCY=4
WORKER_LOG_LEVEL=info

# ------------------------------------------------------------
# Object storage (S3-compatible; use MinIO locally)
# ------------------------------------------------------------
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_ACCESS_KEY=minioadmin
OBJECT_STORAGE_SECRET_KEY=minioadmin
OBJECT_STORAGE_BUCKET=atlas-sources
OBJECT_STORAGE_REGION=us-east-1

# ------------------------------------------------------------
# Vault
# ------------------------------------------------------------
# Absolute path to the local Markdown vault directory
VAULT_PATH=./vault

# ------------------------------------------------------------
# LLM providers
# ------------------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Default model used for compilation and answer generation
DEFAULT_LLM_MODEL=claude-sonnet-4-6

# ------------------------------------------------------------
# Optional tools profile (docker compose --profile tools)
# ------------------------------------------------------------
ADMINER_PORT=8080

# ------------------------------------------------------------
# Observability
# ------------------------------------------------------------
LOG_LEVEL=info
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=atlas
